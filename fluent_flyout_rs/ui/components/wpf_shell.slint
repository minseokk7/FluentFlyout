export component WpfNavigationRailItem inherits Rectangle {
    in property <image> iconSource;
    in property <bool> active: false;
    callback clicked;

    width: 48px;
    height: 48px;
    border-radius: 7px;
    background: active ? #2d2f2d : #00000000;
    border-width: active ? 1px : 0px;
    border-color: active ? #7b807b : #00000000;

    Image {
        x: parent.width / 2 - 8px;
        y: parent.height / 2 - 8px;
        width: 16px;
        height: 16px;
        source: iconSource;
        opacity: active ? 1 : 0.9;
    }

    TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

export component WpfTitleBlock inherits Rectangle {
    in property <string> title;
    in property <string> versionText;

    width: 380px;
    height: 40px;
    background: #00000000;

    Text {
        x: 0;
        y: 0;
        text: title;
        color: #f5f8fc;
        font-size: 24px;
        font-weight: 500;
    }

    Text {
        x: 250px;
        y: 7px;
        text: versionText;
        color: #8f948f;
        font-size: 13px;
    }
}

export component WpfPageHeader inherits Rectangle {
    in property <string> title;

    width: 644px;
    height: 32px;
    background: #00000000;

    Text {
        x: 0;
        y: 0;
        text: title;
        color: #f1f3f0;
        font-size: 24px;
        font-weight: 700;
    }
}

export component WpfDashboardActionCard inherits Rectangle {
    in property <image> iconSource;
    in property <string> title;
    in property <string> subtitle;
    in property <bool> premium: false;
    callback clicked;

    width: 302px;
    height: 88px;
    border-radius: 8px;
    border-width: 1px;
    border-color: #333633;
    background: #2d2f2c;

    Image {
        x: 18px;
        y: parent.height / 2 - 13px;
        width: 26px;
        height: 26px;
        source: iconSource;
    }

    Text {
        x: 64px;
        y: 20px;
        text: title;
        color: #f1f3f0;
        font-size: 13px;
        font-weight: 500;
    }

    Rectangle {
        visible: premium;
        x: parent.width - 86px;
        y: 19px;
        width: 60px;
        height: 18px;
        border-radius: 9px;
        background: #565956;

        Text {
            x: 0;
            y: parent.height / 2 - self.height / 2;
            width: parent.width;
            text: "PREMIUM";
            color: #dfdfdf;
            font-size: 8px;
            font-weight: 700;
            horizontal-alignment: center;
        }
    }

    Text {
        x: 64px;
        y: 46px;
        text: subtitle;
        color: #b4b8b5;
        font-size: 12px;
    }

    Image {
        x: parent.width - 24px;
        y: parent.height / 2 - 7px;
        width: 14px;
        height: 14px;
        source: @image-url("../icons/chevron-right.svg");
    }

    TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

export component WpfHeroBlock inherits Rectangle {
    in property <string> description;
    in property <image> previewImage;

    width: 624px;
    height: 128px;
    background: #00000000;

    Rectangle {
        x: 0;
        y: 6px;
        width: 164px;
        height: 98px;
        border-radius: 10px;
        clip: true;
        background: #303332;

        Image {
            x: 0;
            y: 0;
            width: parent.width;
            height: parent.height;
            source: previewImage;
            image-fit: cover;
        }
    }

    Text {
        x: 176px;
        y: 8px;
        width: 428px;
        text: description;
        color: #d1d5d1;
        font-size: 14px;
        wrap: word-wrap;
    }
}

export component WpfToggleCard inherits Rectangle {
    in property <string> iconText: "◉";
    in property <string> title;
    in property <string> subtitle;
    in property <string> badgeText: "";
    in property <bool> badgeSuccess: false;
    in property <bool> value: false;
    callback toggled;

    width: 624px;
    height: 82px;
    border-radius: 8px;
    border-width: 1px;
    border-color: #323532;
    background: #2b2d2b;

    Text {
        x: 18px;
        y: parent.height / 2 - self.height / 2;
        width: 28px;
        text: iconText;
        color: #f1f3f0;
        font-size: 24px;
        font-family: "Segoe Fluent Icons";
        horizontal-alignment: center;
    }

    Text {
        x: 64px;
        y: 18px;
        text: title;
        color: #f2f4f1;
        font-size: 14px;
        font-weight: 600;
    }

    Rectangle {
        visible: badgeText != "";
        x: 250px;
        y: 18px;
        width: badgeText == "PREMIUM" ? 58px : 40px;
        height: 20px;
        border-radius: 10px;
        background: badgeSuccess ? #6fd44e : #4d504d;

        Text {
            x: 0;
            y: parent.height / 2 - self.height / 2;
            width: parent.width;
            text: badgeText;
            color: badgeSuccess ? #173010 : #eceeeb;
            font-size: 9px;
            font-weight: 700;
            horizontal-alignment: center;
        }
    }

    Text {
        x: 64px;
        y: 42px;
        width: parent.width - 176px;
        text: subtitle;
        color: #b0b4b0;
        font-size: 12px;
        wrap: word-wrap;
        max-height: 28px;
    }

    Rectangle {
        x: parent.width - 64px;
        y: 27px;
        width: 48px;
        height: 28px;
        border-radius: 14px;
        border-width: value ? 0px : 1px;
        border-color: #d7dbd6;
        background: value ? #727572 : #00000000;

        Rectangle {
            x: value ? 24px : 2px;
            y: 2px;
            width: 22px;
            height: 24px;
            border-radius: 11px;
            background: value ? #101111 : #ffffff;
        }

        TouchArea {
            clicked => {
                root.toggled();
            }
        }
    }
}

export component WpfSelectCard inherits Rectangle {
    in property <string> iconText: "▤";
    in property <string> title;
    in property <string> subtitle: "";
    in property <string> badgeText: "";
    in property <bool> badgeSuccess: false;
    in property <string> valueText;
    callback activated;

    width: 624px;
    height: 82px;
    border-radius: 8px;
    border-width: 1px;
    border-color: #323532;
    background: #2b2d2b;

    Text {
        x: 18px;
        y: parent.height / 2 - self.height / 2;
        width: 28px;
        text: iconText;
        color: #f1f3f0;
        font-size: 24px;
        font-family: "Segoe Fluent Icons";
        horizontal-alignment: center;
    }

    Text {
        x: 64px;
        y: subtitle == "" ? 29px : 18px;
        text: title;
        color: #f2f4f1;
        font-size: 14px;
        font-weight: 600;
    }

    Rectangle {
        visible: badgeText != "";
        x: 250px;
        y: 18px;
        width: badgeText == "PREMIUM" ? 58px : 40px;
        height: 20px;
        border-radius: 10px;
        background: badgeSuccess ? #6fd44e : #4d504d;

        Text {
            x: 0;
            y: parent.height / 2 - self.height / 2;
            width: parent.width;
            text: badgeText;
            color: badgeSuccess ? #173010 : #eceeeb;
            font-size: 9px;
            font-weight: 700;
            horizontal-alignment: center;
        }
    }

    Text {
        visible: subtitle != "";
        x: 64px;
        y: 42px;
        width: parent.width - 220px;
        text: subtitle;
        color: #b0b4b0;
        font-size: 12px;
        wrap: word-wrap;
        max-height: 28px;
    }

    Rectangle {
        x: parent.width - 148px;
        y: 20px;
        width: 132px;
        height: 40px;
        border-radius: 6px;
        border-width: 1px;
        border-color: #434643;
        background: #343634;

        Text {
            x: 14px;
            y: parent.height / 2 - self.height / 2;
            width: parent.width - 34px;
            text: valueText;
            color: #f1f3f0;
            font-size: 12px;
        }

        Text {
            x: parent.width - 24px;
            y: parent.height / 2 - self.height / 2;
            text: "▾";
            color: #f1f3f0;
            font-size: 12px;
            font-family: "Segoe Fluent Icons";
        }

        TouchArea {
            clicked => {
                root.activated();
            }
        }
    }
}

export component WpfStepperCard inherits Rectangle {
    in property <string> iconText: "⏱";
    in property <string> title;
    in property <string> subtitle;
    in property <string> badgeText: "";
    in property <bool> badgeSuccess: false;
    in property <string> unitText: "";
    in property <int> value;
    callback decrement;
    callback increment;

    width: 624px;
    height: 82px;
    border-radius: 8px;
    border-width: 1px;
    border-color: #323532;
    background: #2b2d2b;

    Text {
        x: 18px;
        y: parent.height / 2 - self.height / 2;
        width: 28px;
        text: iconText;
        color: #f1f3f0;
        font-size: 24px;
        font-family: "Segoe Fluent Icons";
        horizontal-alignment: center;
    }

    Text {
        x: 64px;
        y: 18px;
        text: title;
        color: #f2f4f1;
        font-size: 14px;
        font-weight: 600;
    }

    Text {
        x: 64px;
        y: 42px;
        width: parent.width - 240px;
        text: subtitle;
        color: #b0b4b0;
        font-size: 12px;
        wrap: word-wrap;
        max-height: 28px;
    }

    Rectangle {
        x: parent.width - 122px;
        y: 18px;
        width: unitText == "" ? 68px : 76px;
        height: 40px;
        border-radius: 8px;
        border-width: 1px;
        border-color: #4a4d4a;
        background: #343634;

        Text {
            x: 0;
            y: parent.height / 2 - self.height / 2;
            width: parent.width;
            text: value;
            color: #f1f3f0;
            font-size: 13px;
            font-weight: 600;
            horizontal-alignment: center;
        }
    }

    Text {
        visible: unitText != "";
        x: parent.width - 38px;
        y: 28px;
        text: unitText;
        color: #f1f3f0;
        font-size: 12px;
    }

    Rectangle {
        x: parent.width - 158px;
        y: 26px;
        width: 28px;
        height: 28px;
        border-radius: 14px;
        background: #243547;

        Text {
            x: 0;
            y: parent.height / 2 - self.height / 2;
            width: parent.width;
            text: "-";
            color: #f6f8fb;
            font-size: 12px;
            font-weight: 700;
            horizontal-alignment: center;
        }

        TouchArea { clicked => { root.decrement(); } }
    }

    Rectangle {
        x: parent.width - 48px - (unitText != "" ? 30px : 0px);
        y: 26px;
        width: 28px;
        height: 28px;
        border-radius: 14px;
        background: #5d92f6;

        Text {
            x: 0;
            y: parent.height / 2 - self.height / 2;
            width: parent.width;
            text: "+";
            color: #f6f8fb;
            font-size: 12px;
            font-weight: 700;
            horizontal-alignment: center;
        }

        TouchArea { clicked => { root.increment(); } }
    }
}

export component WpfFooterLinkCard inherits Rectangle {
    in property <image> iconSource;
    in property <string> label;
    callback clicked;

    width: 128px;
    height: 52px;
    border-radius: 10px;
    background: #00000000;

    Image {
        x: parent.width / 2 - 9px;
        y: 2px;
        width: 18px;
        height: 18px;
        source: iconSource;
    }

    Text {
        x: 0;
        y: 26px;
        width: parent.width;
        text: label;
        color: #f0f3f0;
        font-size: 12px;
        horizontal-alignment: center;
    }

    TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

export component WpfInfoBar inherits Rectangle {
    in property <string> text;
    in property <bool> informational: true;

    width: 624px;
    height: 50px;
    border-radius: 8px;
    background: informational ? #343834 : #6b5115;

    Rectangle {
        x: 18px;
        y: parent.height / 2 - 8px;
        width: 16px;
        height: 16px;
        border-radius: 8px;
        background: #4a4d4a;

        Text {
            x: 0;
            y: parent.height / 2 - self.height / 2;
            width: parent.width;
            text: "i";
            color: #171818;
            font-size: 10px;
            font-weight: 700;
            horizontal-alignment: center;
        }
    }

    Text {
        x: 46px;
        y: parent.height / 2 - self.height / 2;
        width: parent.width - 64px;
        text: text;
        color: #f1f3f0;
        font-size: 13px;
        font-weight: 600;
        wrap: word-wrap;
    }
}

export component WpfAnchorButton inherits Rectangle {
    in property <string> label;
    in property <string> iconText;
    callback clicked;

    width: 126px;
    height: 36px;
    border-radius: 6px;
    border-width: 1px;
    border-color: #5a5d5a;
    background: #2c2f2c;

    Text {
        x: 12px;
        y: parent.height / 2 - self.height / 2;
        text: iconText;
        color: #f1f3f0;
        font-size: 12px;
        font-weight: 600;
    }

    Text {
        x: 30px;
        y: parent.height / 2 - self.height / 2;
        width: parent.width - 40px;
        text: label;
        color: #f1f3f0;
        font-size: 12px;
    }

    TouchArea {
        clicked => {
            root.clicked();
        }
    }
}
