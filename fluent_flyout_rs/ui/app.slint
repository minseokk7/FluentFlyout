import { ScrollView, Slider } from "std-widgets.slint";
import { WpfAnchorButton, WpfDashboardActionCard, WpfFooterLinkCard, WpfHeroBlock, WpfInfoBar, WpfNavigationRailItem, WpfPageHeader, WpfSelectCard, WpfStepperCard, WpfTitleBlock, WpfToggleCard } from "components/wpf_shell.slint";

component ControlChip inherits Rectangle {
    in property <string> label;
    in property <bool> emphasized: false;
    in property <bool> enabled: true;
    in property <float> glyphOpacity: 1.0;
    callback clicked;

    width: emphasized ? 32px : 28px;
    height: emphasized ? 32px : 28px;
    border-radius: emphasized ? 16px : 14px;
    background: emphasized ? #5d92f6 : #243547;
    opacity: enabled ? 1 : 0.35;

    Text {
        x: 0;
        y: parent.height / 2 - self.height / 2;
        width: parent.width;
        text: label;
        color: #f6f8fb;
        font-size: emphasized ? 13px : 12px;
        font-weight: 700;
        horizontal-alignment: center;
        opacity: glyphOpacity;
    }

    TouchArea {
        enabled: parent.enabled;
        clicked => {
            root.clicked();
        }
    }
}

component SettingsNavItem inherits Rectangle {
    in property <image> iconSource;
    in property <string> titleText;
    in property <bool> active: false;
    in property <bool> compact: false;
    callback clicked;

    width: compact ? 42px : 210px;
    height: compact ? 42px : 42px;
    border-radius: compact ? 7px : 8px;
    background: active ? #2d302d : #00000000;
    border-width: compact && active ? 1px : 0px;
    border-color: compact && active ? #bfc5bf : #00000000;

    Image {
        x: compact ? parent.width / 2 - 7px : 16px;
        y: parent.height / 2 - 7px;
        width: 14px;
        height: 14px;
        source: iconSource;
        opacity: active ? 1 : 0.92;
    }

    Text {
        visible: !compact;
        x: 48px;
        y: parent.height / 2 - self.height / 2;
        width: parent.width - 64px;
        text: titleText;
        color: active ? #f6f8fb : #d2d6d2;
        font-size: 14px;
        font-weight: active ? 600 : 500;
    }

    TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component SettingsToggleCard inherits Rectangle {
    in property <string> iconText: "";
    in property <string> title;
    in property <string> subtitle;
    in property <string> badgeText: "";
    in property <bool> badgeSuccess: false;
    in property <bool> value: false;
    callback toggled;

    width: 624px;
    height: 82px;
    border-radius: 8px;
    border-width: 1px;
    border-color: #323532;
    background: #2b2d2b;

    Text {
        x: 18px;
        y: parent.height / 2 - self.height / 2;
        width: 28px;
        text: iconText;
        color: #f1f3f0;
        font-size: 24px;
        font-family: "Segoe Fluent Icons";
        horizontal-alignment: center;
    }

    Text {
        x: 64px;
        y: 18px;
        text: title;
        color: #f2f4f1;
        font-size: 14px;
        font-weight: 600;
    }

    Rectangle {
        visible: badgeText != "";
        x: 250px;
        y: 18px;
        width: badgeText == "PREMIUM" ? 58px : 40px;
        height: 20px;
        border-radius: 6px;
        background: badgeSuccess ? #6fd44e : #4d504d;

        Text {
            x: 0;
            y: parent.height / 2 - self.height / 2;
            width: parent.width;
            text: badgeText;
            color: badgeSuccess ? #173010 : #eceeeb;
            font-size: 9px;
            font-weight: 700;
            horizontal-alignment: center;
        }
    }

    Text {
        x: 64px;
        y: 42px;
        width: parent.width - 176px;
        text: subtitle;
        color: #b0b4b0;
        font-size: 12px;
        wrap: word-wrap;
        max-height: 28px;
    }

    Rectangle {
        x: parent.width - 64px;
        y: 27px;
        width: 48px;
        height: 28px;
        border-radius: 14px;
        border-width: value ? 0px : 1px;
        border-color: #d7dbd6;
        background: value ? #727572 : #00000000;

        Rectangle {
            x: value ? 24px : 2px;
            y: 2px;
            width: 22px;
            height: 24px;
            border-radius: 11px;
            background: value ? #101111 : #ffffff;
        }

        TouchArea {
            clicked => {
                root.toggled();
            }
        }
    }
}

component SettingsStepperCard inherits Rectangle {
    in property <string> iconText: "";
    in property <string> title;
    in property <string> subtitle;
    in property <string> badgeText: "";
    in property <bool> badgeSuccess: false;
    in property <string> unitText: "";
    in property <int> value;
    callback decrement;
    callback increment;

    width: 624px;
    height: 82px;
    border-radius: 8px;
    border-width: 1px;
    border-color: #323532;
    background: #2b2d2b;

    Text {
        x: 18px;
        y: parent.height / 2 - self.height / 2;
        width: 28px;
        text: iconText;
        color: #f1f3f0;
        font-size: 24px;
        font-family: "Segoe Fluent Icons";
        horizontal-alignment: center;
    }

    Text {
        x: 64px;
        y: 18px;
        text: title;
        color: #f2f4f1;
        font-size: 14px;
        font-weight: 600;
    }

    Rectangle {
        visible: badgeText != "";
        x: 250px;
        y: 18px;
        width: badgeText == "PREMIUM" ? 58px : 40px;
        height: 20px;
        border-radius: 6px;
        background: badgeSuccess ? #6fd44e : #4d504d;

        Text {
            x: 0;
            y: parent.height / 2 - self.height / 2;
            width: parent.width;
            text: badgeText;
            color: badgeSuccess ? #173010 : #eceeeb;
            font-size: 9px;
            font-weight: 700;
            horizontal-alignment: center;
        }
    }

    Text {
        x: 64px;
        y: 42px;
        width: parent.width - 240px;
        text: subtitle;
        color: #b0b4b0;
        font-size: 12px;
        wrap: word-wrap;
        max-height: 28px;
    }

    ControlChip {
        x: parent.width - 158px;
        y: 26px;
        label: "-";
        emphasized: false;
        clicked => {
            root.decrement();
        }
    }

    Rectangle {
        x: parent.width - 122px;
        y: 18px;
        width: unitText == "" ? 68px : 76px;
        height: 40px;
        border-radius: 8px;
        border-width: 1px;
        border-color: #4a4d4a;
        background: #343634;

        Text {
            x: 0;
            y: parent.height / 2 - self.height / 2;
            width: parent.width;
            text: value;
            color: #f1f3f0;
            font-size: 13px;
            font-weight: 600;
            horizontal-alignment: center;
        }
    }

    Text {
        visible: unitText != "";
        x: parent.width - 38px;
        y: 28px;
        text: unitText;
        color: #f1f3f0;
        font-size: 12px;
    }

    ControlChip {
        x: parent.width - 48px - (unitText != "" ? 30px : 0px);
        y: 26px;
        label: "+";
        clicked => {
            root.increment();
        }
    }
}

component SettingsInfoBar inherits Rectangle {
    in property <string> text;
    in property <bool> warning: false;
    in property <bool> informational: false;

    width: 624px;
    height: 40px;
    border-radius: 6px;
    background: warning ? #6b5115 : (informational ? #323532 : #2b2d2b);

    Text {
        x: 16px;
        y: parent.height / 2 - self.height / 2;
        width: 20px;
        text: warning ? "!" : "i";
        color: warning ? #ffdd5c : #8d9190;
        font-size: 18px;
        font-family: "Segoe Fluent Icons";
        horizontal-alignment: center;
    }

    Text {
        x: 44px;
        y: parent.height / 2 - self.height / 2;
        width: parent.width - 60px;
        text: text;
        color: #f1f3f0;
        font-size: 13px;
        font-weight: 600;
        wrap: word-wrap;
    }
}

