component SettingsHeroBlock inherits Rectangle {
    in property <string> description;
    in property <image> previewImage;

    width: 624px;
    height: 112px;
    background: #00000000;

    Rectangle {
        x: 0;
        y: 6px;
        width: 164px;
        height: 98px;
        border-radius: 6px;
        clip: true;
        background: #303332;

        Image {
            x: 0;
            y: 0;
            width: parent.width;
            height: parent.height;
            source: previewImage;
            image-fit: cover;
        }
    }

    Text {
        x: 176px;
        y: 8px;
        width: 428px;
        text: description;
        color: #d1d5d1;
        font-size: 14px;
        wrap: word-wrap;
    }
}

