component DashboardActionCard inherits Rectangle {
    in property <image> iconSource;
    in property <string> title;
    in property <string> subtitle;
    in property <bool> premium: false;
    callback clicked;

    width: 302px;
    height: 94px;
    border-radius: 8px;
    border-width: 1px;
    border-color: #353835;
    background: #2d2f2d;

    Image {
        x: 18px;
        y: parent.height / 2 - 14px;
        width: 28px;
        height: 28px;
        source: iconSource;
    }

    Text {
        x: 64px;
        y: 24px;
        text: title;
        color: #f1f3f0;
        font-size: 14px;
        font-weight: 600;
    }

    Rectangle {
        visible: premium;
        x: parent.width - 88px;
        y: 23px;
        width: 62px;
        height: 18px;
        border-radius: 9px;
        background: #505350;

        Text {
            x: 0;
            y: parent.height / 2 - self.height / 2;
            width: parent.width;
            text: "PREMIUM";
            color: #dfdfdf;
            font-size: 8px;
            font-weight: 700;
            horizontal-alignment: center;
        }
    }

    Text {
        x: 64px;
        y: 52px;
        text: subtitle;
        color: #b4b8b5;
        font-size: 12px;
    }

    Image {
        x: parent.width - 24px;
        y: parent.height / 2 - 8px;
        width: 16px;
        height: 16px;
        source: @image-url("icons/chevron-right.svg");
    }

    TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component FooterLinkCard inherits Rectangle {
    in property <image> iconSource;
