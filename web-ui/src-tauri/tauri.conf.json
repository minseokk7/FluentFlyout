{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FluentFlyout",
  "version": "3.1.5",
  "identifier": "com.fluentflyout.rust",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "FluentFlyout",
        "width": 900,
        "height": 700,
        "minWidth": 750,
        "minHeight": 300,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true
      },
      {
        "label": "media-flyout",
        "title": "FluentFlyout Media Flyout",
        "width": 310,
        "height": 116,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": true
      },
      {
        "label": "next-up-flyout",
        "title": "FluentFlyout Next Up",
        "width": 250,
        "height": 62,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": true
      },
      {
        "label": "lock-keys-flyout",
        "title": "FluentFlyout Lock Keys",
        "width": 190,
        "height": 50,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": true
      },
      {
        "label": "taskbar-widget",
        "title": "FluentFlyout Taskbar Widget",
        "width": 100,
        "height": 40,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": {
      "../../FluentFlyoutDisplayHost/bin/x64/Release/net10.0-windows10.0.22000.0/*": "display-host/"
    }
  }
}
